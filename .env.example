# Copy this file to .env and fill in your values.
# .env is gitignored - never commit real credentials.

# --- Core ServiceNow connection ---
SN_INSTANCE_URL=https://your-instance.service-now.com
SN_AUTH_MODE=basic
SN_USERNAME=your-username
SN_PASSWORD=your-password
SN_BEARER_TOKEN=

# --- Snapshot sync defaults (app + sync_snapshot.py) ---
DB_PATH=db/data.sqlite
SN_SINCE_DAYS=30
SN_INCIDENT_MAX=5000
SN_REQUEST_MAX=5000
SN_CHANGE_MAX=3000
SN_PROBLEM_MAX=3000
SN_TIMEOUT=20

# --- Optional Azure app registration notes (if you use bearer acquisition flow) ---
# AZURE_CLIENT_ID=your-azure-client-id
# AZURE_CLIENT_SECRET=your-azure-client-secret
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_SCOPE=api://[from KB]/.default