# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
SN_INSTANCE_URL=https://[from KB].service-now.com
AZURE_SCOPE=api://[from KB]/.default
#https://sas.service-now.com/kb/en/the-servicenow-api-acquiring-access-tokens-from-azure?id=kb_article_view&sysparm_article=KB0029526
